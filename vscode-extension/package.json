{
  "name": "pi-ide-bridge-vscode",
  "displayName": "Pi IDE Bridge",
  "description": "VS Code companion for the Pi coding agent — bridges editor context, diff review, and diagnostics.",
  "version": "0.2.3",
  "publisher": "m4riok",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/m4riok/pi-ide-bridge"
  },
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "scripts": {
    "check": "node --check src/extension.js && tsc --noEmit -p jsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "@types/vscode": "^1.90.0",
    "typescript": "^6.0.3"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "piIdeBridge.openDiffForApproval",
        "title": "Pi IDE Bridge: Open Diff For Approval"
      },
      {
        "command": "piIdeBridge.approveActiveDiff",
        "title": "Approve Change",
        "icon": "$(check)"
      },
      {
        "command": "piIdeBridge.showBridgeDebug",
        "title": "Pi IDE Bridge: Show Debug Info"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "piIdeBridge.approveActiveDiff",
          "when": "pi.diff.isVisible",
          "group": "navigation@0"
        }
      ]
    },
    "keybindings": []
  }
}

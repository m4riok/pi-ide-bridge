{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Pi IDE Bridge Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/vscode-extension",
        "--folder-uri=vscode-remote://wsl+opensuse-tumbleweed/tmp/test-extension"
      ],
      "outFiles": [
        "${workspaceFolder}/vscode-extension/**/*.js"
      ]
    }
  ]
}
